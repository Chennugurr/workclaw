{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generated schema for Root",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "releaseDate": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": ["type", "date", "description"]
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": ["name", "description"]
      }
    },
    "knownIssues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deprecations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "version",
    "releaseDate",
    "description",
    "updates",
    "features",
    "knownIssues",
    "deprecations"
  ]
}
