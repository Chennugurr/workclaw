// Workclaw - Web3 AI Work Platform
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// Enums - Existing (kept)
// ============================================================================

enum Gender {
  MALE
  FEMALE
  OTHERS
  UNDEFINED
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum Education {
  HIGH_SCHOOL
  ASSOCIATE_DEGREE
  BACHELOR_DEGREE
  MASTER_DEGREE
  DOCTORATE
  PROFESSIONAL_CERTIFICATION
  VOCATIONAL_TRAINING
  OTHER
}

enum Experience {
  INTERNSHIP
  ENTRY_LEVEL
  MID_LEVEL
  SENIOR_LEVEL
  MANAGEMENT
  DIRECTOR
  EXECUTIVE
  CONSULTANT
  FREELANCE
}

enum Availability {
  AVAILABLE
  UNAVAILABLE
}

enum SocialPlatform {
  TWITTER
  LINKEDIN
  FACEBOOK
  INSTAGRAM
  GITHUB
  WEBSITE
  FARCASTER
  OTHER
}

enum SocialOwnerType {
  USER
  ORGANIZATION
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum SkillOwnerType {
  USER
  PROJECT
}

enum OrganizationType {
  STARTUP
  SMALL_BUSINESS
  CORPORATION
  NON_PROFIT
  GOVERNMENT
  EDUCATIONAL
  HEALTHCARE
  FINTECH
  ECOMMERCE
  TECHNOLOGY
  CONSULTING
  OTHER
}

enum OrganizationTeamSize {
  ONE_TO_TEN
  ELEVEN_TO_FIFTY
  FIFTY_ONE_TO_TWO_HUNDRED
  TWO_HUNDRED_ONE_TO_FIVE_HUNDRED
  FIVE_HUNDRED_ONE_TO_ONE_THOUSAND
  OVER_ONE_THOUSAND
}

enum OrganizationStaffRole {
  OWNER
  ADMIN
  MEMBER
}

// ============================================================================
// Enums - New
// ============================================================================

enum UserRole {
  CONTRIBUTOR
  CUSTOMER
  REVIEWER
  ADMIN
}

enum ContributorTier {
  NEW
  VERIFIED
  SKILLED
  TRUSTED
  EXPERT
  ELITE_REVIEWER
}

enum KYCStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum CryptoExperience {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum Currency {
  USDC
}

enum TaskType {
  SINGLE_RESPONSE_RATING
  PAIRWISE_COMPARISON
  MULTI_RESPONSE_RANKING
  LABEL_CLASSIFICATION
  TEXT_ANNOTATION
  CODE_REVIEW
  FACTUALITY_VERIFICATION
  SAFETY_REVIEW
  SCAM_CLASSIFICATION
  CONTRACT_VALIDATION
  RESEARCH_GRADING
  AGENT_EVALUATION
  PROMPT_WRITING
  TRANSLATION_REVIEW
}

enum PayModel {
  PER_TASK
  HOURLY
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum ProjectStatus {
  DRAFT
  SCREENING_SETUP
  INVITE_ONLY
  OPEN
  PAUSED
  FULL
  ARCHIVED
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum TaskStatus {
  AVAILABLE
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum BatchStatus {
  PENDING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum ReviewVerdict {
  APPROVED
  REJECTED
  REVISION_REQUESTED
  ESCALATED
}

enum ScreeningStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  SCENARIO_BASED
  MANUAL_REVIEW
}

enum PayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  DISPUTED
  HELD
}

enum PayoutMethodType {
  SOLANA_WALLET
  ETHEREUM_WALLET
  FIAT_PLACEHOLDER
  PAYPAL_PLACEHOLDER
}

enum LedgerEntryType {
  TASK_EARNING
  BONUS
  STREAK_INCENTIVE
  QUALITY_BONUS
  REFERRAL_CREDIT
  MANUAL_ADJUSTMENT
  PAYOUT_DEBIT
  REVERSAL
  HOLD
}

enum DisputeType {
  TASK_REVIEW
  PAYOUT
  ACCOUNT
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum FraudSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudFlagStatus {
  OPEN
  INVESTIGATING
  CONFIRMED
  DISMISSED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================================================
// Models - Extended from detask
// ============================================================================

model User {
  id                 String          @id @default(dbgenerated("nanoid()"))
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  address            String          @unique
  role               UserRole        @default(CONTRIBUTOR)
  tier               ContributorTier @default(NEW)
  onboardingComplete Boolean         @default(false)
  kycStatus          KYCStatus       @default(NONE)

  profile            Profile?
  socials            Social[]
  session            Session[]
  skills             SkillAssociation[]
  orgs               OrganizationStaff[]
  applications       Application[]
  taskSubmissions    TaskSubmission[]
  screeningAttempts  ScreeningAttempt[]
  contributorScores  ContributorScore[]
  reputationEvents   ReputationEvent[]
  payoutMethods      PayoutMethod[]
  payouts            Payout[]
  notifications      Notification[]
  fraudFlags         FraudFlag[]
  supportTickets     SupportTicket[]
  reviewerAssignments ReviewerAssignment[]

  @@map("users")
}

model Profile {
  id                       String           @id @default(dbgenerated("nanoid()"))
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  userId                   String           @unique
  firstName                String           @db.VarChar(50)
  middleName               String?          @db.VarChar(50)
  lastName                 String           @db.VarChar(50)
  title                    String
  email                    String?          @unique
  phone                    String?
  website                  String?
  location                 String?
  nationality              String?
  dateOfBirth              DateTime?
  gender                   Gender?
  maritalStatus            MaritalStatus?
  education                Education?
  experience               Experience?
  availability             Availability     @default(AVAILABLE)
  bio                      String?          @db.Text
  pfp                      String?
  // New contributor fields
  cryptoExperienceLevel    CryptoExperience?
  chainsOfExpertise        String[]
  protocolsOfExpertise     String[]
  codingLanguages          String[]
  moderationExperience     Boolean          @default(false)
  researchExperience       Boolean          @default(false)
  fraudDetectionExperience Boolean          @default(false)
  languagesSpoken          String[]
  timezone                 String?
  country                  String?
  farcaster                String?
  ens                      String?
  payoutEligibility        Boolean          @default(false)
  trustScore               Float            @default(0)
  reviewerScore            Float            @default(0)
  integrityScore           Float            @default(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Social {
  id          String          @id @default(dbgenerated("nanoid()"))
  userId      String?
  orgId       String?
  platform    SocialPlatform
  handleOrUrl String
  ownerType   SocialOwnerType

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("socials")
}

model Session {
  id           String        @id @default(dbgenerated("nanoid()"))
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userId       String
  accessToken  String        @unique
  refreshToken String        @unique
  status       SessionStatus @default(ACTIVE)
  expiresAt    DateTime
  lastSeenAt   DateTime?
  ipAddress    String?
  userAgent    String?
  location     String?
  deviceInfo   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt, lastSeenAt])
  @@map("sessions")
}

model Skill {
  id          String   @id @default(dbgenerated("nanoid()"))
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String   @unique
  description String?  @db.Text
  verified    Boolean  @default(false)
  icon        String?
  category    String?

  associations SkillAssociation[]

  @@index([name])
  @@map("skills")
}

model SkillAssociation {
  id        String          @id @default(dbgenerated("nanoid()"))
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  userId    String?
  projectId String?
  skillId   String
  level     ExperienceLevel
  ownerType SkillOwnerType

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill   Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@unique([projectId, skillId])
  @@index([level])
  @@map("skill_associations")
}

model Organization {
  id           String               @id @default(dbgenerated("nanoid()"))
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  name         String               @db.VarChar(100)
  email        String?              @unique
  phone        String?
  website      String?
  location     String?
  foundedIn    DateTime?
  type         OrganizationType
  teamSize     OrganizationTeamSize
  bio          String?              @db.Text
  logo         String?
  banner       String?
  customerType String?

  staffs   OrganizationStaff[]
  projects Project[]
  socials  Social[]

  @@index([name])
  @@map("organizations")
}

model OrganizationStaff {
  id        String                @unique @default(dbgenerated("nanoid()"))
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  userId    String
  orgId     String
  role      OrganizationStaffRole

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([userId, orgId])
  @@map("organization_staffs")
}

// ============================================================================
// Models - Renamed / Rewritten
// ============================================================================

model Project {
  id                   String            @id @default(dbgenerated("nanoid()"))
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  orgId                String
  title                String            @db.VarChar(200)
  slug                 String            @unique
  description          String            @db.Text
  taskType             TaskType
  domain               String[]
  chainTags            String[]
  modelOrUseCase       String?
  payModel             PayModel
  rateAmount           Decimal?
  currency             Currency          @default(USDC)
  difficulty           Difficulty        @default(INTERMEDIATE)
  qualityThreshold     Float             @default(0.8)
  qualityBonusEligible Boolean           @default(false)
  capacity             Int?
  taskVolume           Int?
  goldTaskRatio        Float             @default(0.05)
  startDate            DateTime?
  endDate              DateTime?
  status               ProjectStatus     @default(DRAFT)
  visibility           ProjectVisibility @default(PUBLIC)
  regionLimits         String[]
  languageLimits       String[]
  requiredTier         ContributorTier   @default(NEW)
  reviewPolicy         String?           @db.Text
  disputeRules         String?           @db.Text
  payoutRules          String?           @db.Text

  organization        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  skills              SkillAssociation[]
  applications        Application[]
  tasks               Task[]
  taskBatches         TaskBatch[]
  screenings          Screening[]
  reviewerAssignments ReviewerAssignment[]

  @@index([createdAt, updatedAt, orgId, status])
  @@map("projects")
}

model Application {
  id        String            @id @default(dbgenerated("nanoid()"))
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  userId    String
  projectId String
  status    ApplicationStatus @default(PENDING)
  note      String?           @db.Text

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("applications")
}

model ReviewerAssignment {
  id        String   @id @default(dbgenerated("nanoid()"))
  createdAt DateTime @default(now())
  userId    String
  projectId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("reviewer_assignments")
}

// ============================================================================
// Models - New
// ============================================================================

model Task {
  id           String     @id @default(dbgenerated("nanoid()"))
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  projectId    String
  batchId      String?
  taskType     TaskType
  data         Json
  instructions String?    @db.Text
  rubric       Json?
  examples     Json?
  isGold       Boolean    @default(false)
  goldAnswer   Json?
  status       TaskStatus @default(AVAILABLE)
  assignedTo   String?
  assignedAt   DateTime?
  dueAt        DateTime?
  priority     Int        @default(0)

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  batch       TaskBatch?       @relation(fields: [batchId], references: [id])
  submissions TaskSubmission[]

  @@index([projectId, status])
  @@index([assignedTo, status])
  @@map("tasks")
}

model TaskBatch {
  id        String      @id @default(dbgenerated("nanoid()"))
  createdAt DateTime    @default(now())
  projectId String
  name      String
  taskCount Int         @default(0)
  status    BatchStatus @default(PENDING)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("task_batches")
}

model TaskSubmission {
  id           String           @id @default(dbgenerated("nanoid()"))
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  taskId       String
  userId       String
  response     Json?
  confidence   Float?
  reasoning    String?          @db.Text
  timeSpent    Int?
  isDraft      Boolean          @default(true)
  submittedAt  DateTime?
  status       SubmissionStatus @default(DRAFT)

  task    Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews TaskReview[]

  @@unique([taskId, userId])
  @@map("task_submissions")
}

model TaskReview {
  id           String        @id @default(dbgenerated("nanoid()"))
  createdAt    DateTime      @default(now())
  submissionId String
  reviewerId   String
  verdict      ReviewVerdict
  score        Float?
  comments     String?       @db.Text
  flags        String[]

  submission TaskSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("task_reviews")
}

model Screening {
  id            String          @id @default(dbgenerated("nanoid()"))
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  projectId     String?
  title         String
  description   String?         @db.Text
  domain        String
  passingScore  Float           @default(0.7)
  maxAttempts   Int             @default(3)
  timeLimitMins Int?
  status        ScreeningStatus @default(DRAFT)

  project   Project?            @relation(fields: [projectId], references: [id])
  questions ScreeningQuestion[]
  attempts  ScreeningAttempt[]

  @@map("screenings")
}

model ScreeningQuestion {
  id            String       @id @default(dbgenerated("nanoid()"))
  screeningId   String
  questionType  QuestionType
  question      String       @db.Text
  options       Json?
  correctAnswer Json?
  points        Float        @default(1)
  order         Int

  screening Screening @relation(fields: [screeningId], references: [id], onDelete: Cascade)

  @@map("screening_questions")
}

model ScreeningAttempt {
  id          String    @id @default(dbgenerated("nanoid()"))
  createdAt   DateTime  @default(now())
  screeningId String
  userId      String
  answers     Json
  score       Float?
  passed      Boolean?
  reviewedBy  String?
  completedAt DateTime?

  screening Screening @relation(fields: [screeningId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("screening_attempts")
}

model ContributorScore {
  id               String   @id @default(dbgenerated("nanoid()"))
  updatedAt        DateTime @updatedAt
  userId           String
  projectId        String?
  agreementScore   Float    @default(0)
  goldTaskAccuracy Float    @default(0)
  acceptanceRate   Float    @default(0)
  consistencyScore Float    @default(0)
  speedScore       Float    @default(0)
  overallScore     Float    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("contributor_scores")
}

model ReputationEvent {
  id         String   @id @default(dbgenerated("nanoid()"))
  createdAt  DateTime @default(now())
  userId     String
  eventType  String
  details    Json
  scoreDelta Float    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reputation_events")
}

model Payout {
  id          String       @id @default(dbgenerated("nanoid()"))
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      String
  methodId    String?
  amount      Decimal
  currency    Currency     @default(USDC)
  status      PayoutStatus @default(PENDING)
  txHash      String?
  batchId     String?
  processedAt DateTime?
  note        String?

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  method        PayoutMethod?       @relation(fields: [methodId], references: [id])
  ledgerEntries PayoutLedgerEntry[]

  @@map("payouts")
}

model PayoutMethod {
  id        String           @id @default(dbgenerated("nanoid()"))
  createdAt DateTime         @default(now())
  userId    String
  type      PayoutMethodType
  details   Json
  isPrimary Boolean          @default(false)
  verified  Boolean          @default(false)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payouts Payout[]

  @@map("payout_methods")
}

model PayoutLedgerEntry {
  id        String          @id @default(dbgenerated("nanoid()"))
  createdAt DateTime        @default(now())
  userId    String
  payoutId  String?
  type      LedgerEntryType
  amount    Decimal
  currency  Currency        @default(USDC)
  reference String?
  note      String?

  payout Payout? @relation(fields: [payoutId], references: [id])

  @@index([userId, createdAt])
  @@map("payout_ledger_entries")
}

model Dispute {
  id          String        @id @default(dbgenerated("nanoid()"))
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  raisedBy    String
  type        DisputeType
  referenceId String
  reason      String        @db.Text
  status      DisputeStatus @default(OPEN)
  resolution  String?       @db.Text
  resolvedBy  String?
  resolvedAt  DateTime?

  @@map("disputes")
}

model Notification {
  id        String   @id @default(dbgenerated("nanoid()"))
  createdAt DateTime @default(now())
  userId    String
  type      String
  title     String
  body      String?
  data      Json?
  read      Boolean  @default(false)
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model Announcement {
  id        String    @id @default(dbgenerated("nanoid()"))
  createdAt DateTime  @default(now())
  title     String
  body      String    @db.Text
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdBy String

  @@map("announcements")
}

model FraudFlag {
  id         String          @id @default(dbgenerated("nanoid()"))
  createdAt  DateTime        @default(now())
  userId     String
  type       String
  severity   FraudSeverity
  details    Json
  status     FraudFlagStatus @default(OPEN)
  resolvedBy String?
  resolvedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("fraud_flags")
}

model AuditLog {
  id        String   @id @default(dbgenerated("nanoid()"))
  createdAt DateTime @default(now())
  actorId   String
  action    String
  target    String
  targetId  String
  details   Json?
  ipAddress String?

  @@index([actorId, createdAt])
  @@index([target, targetId])
  @@map("audit_logs")
}

model SupportTicket {
  id        String         @id @default(dbgenerated("nanoid()"))
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  userId    String
  subject   String
  body      String         @db.Text
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(NORMAL)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}
